{
  "name": "masst-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "pre-render-mermaid": "node scripts/pre-render-mermaid.mjs",
    "pre-render-mermaid:seo": "node scripts/pre-render-mermaid-seo.mjs",
    "pre-render-mermaid:seo:skip-upload": "node scripts/pre-render-mermaid-seo.mjs --skip-upload",
    "generate-sitemap": "node scripts/pre-render-mermaid-seo.mjs --sitemap-only",
    "build": "npm run pre-render-mermaid && next build",
    "build:seo": "npm run pre-render-mermaid:seo && next build",
    "dev": "npm run pre-render-mermaid && next dev --turbo",
    "dev:fast": "next dev --turbo",
    "dev:watch": "node scripts/watch-mermaid.mjs",
    "start": "next start",
    "postinstall": "fumadocs-mdx",
    "generate-embeddings": "tsx scripts/generate-embeddings.ts",
    "evaluate-rag": "tsx scripts/evaluate-rag.ts",
    "evaluate-rag:verbose": "tsx scripts/evaluate-rag.ts --verbose",
    "evaluate-rag:report": "tsx scripts/evaluate-rag.ts --output eval-report.json"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.10",
    "@pinecone-database/pinecone": "^6.1.4",
    "@vercel/analytics": "^2.0.1",
    "ai": "^6.0.49",
    "dotenv": "^17.2.3",
    "fumadocs-core": "15.7.10",
    "fumadocs-mdx": "11.9.0",
    "fumadocs-ui": "15.7.10",
    "groq-sdk": "^0.37.0",
    "mermaid": "^11.11.0",
    "next": "15.4.10",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.4.2",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/mdx": "^2.0.13",
    "@types/node": "24.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^8",
    "eslint-config-next": "15.4.10",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.12.4+sha512.5ea8b0deed94ed68691c9bad4c955492705c5eeb8a87ef86bc62c74a26b037b08ff9570f108b2e4dbd1dd1a9186fea925e527f141c648e85af45631074680184"
